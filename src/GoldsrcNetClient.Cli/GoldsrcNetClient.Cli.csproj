<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\GoldsrcNetClient.Core\GoldsrcNetClient.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CliFx" Version="3.0.0" />
    <PackageReference Include="Facepunch.Steamworks" Version="2.3.3" GeneratePathProperty="true" />
  </ItemGroup>

  <Target Name="CopySteamNativeDll" AfterTargets="Build">
    <Copy SourceFiles="$(PkgFacepunch_Steamworks)\content\steam_api64.dll" DestinationFolder="$(OutputPath)" Condition="Exists('$(PkgFacepunch_Steamworks)\content\steam_api64.dll')" />
  </Target>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
